---
import "../styles/global.css";
import Seo from "@components/Seo.astro";
import SiteHeader from "@components/SiteHeader.astro";
import PreviewModal from "@components/PreviewModal.astro";
import JsonLd from "@components/JsonLd.astro";
import { organizationSchema, websiteSchema } from "@lib/jsonld";
import { BRAND, BRAND_DESCRIPTION, SITE_URL, ORG_ID, WEBSITE_ID, LOGO_URL } from "@lib/site";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  robots?: string;
  ogImage?: string;
  ogType?: string;
}
const { title, description, canonical, robots, ogImage, ogType } = Astro.props;

// Sitewide brand entity (GEO). One Organization + WebSite, with stable @ids the
// rest of the graph can reference, so AI engines resolve a single brand entity.
const org = organizationSchema({
  id: ORG_ID,
  name: BRAND,
  url: `${SITE_URL}/`,
  logo: LOGO_URL,
  description: BRAND_DESCRIPTION,
});
const site = websiteSchema({
  id: WEBSITE_ID,
  name: BRAND,
  url: `${SITE_URL}/`,
  description: BRAND_DESCRIPTION,
  publisherId: ORG_ID,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo
      title={title}
      description={description}
      canonical={canonical}
      robots={robots}
      ogImage={ogImage}
      ogType={ogType}
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#4f46e5" />
    <link rel="preload" href="/fonts/dm-sans-400.woff2" as="font" type="font/woff2" crossorigin />
    <link
      rel="preload"
      href="/fonts/space-grotesk-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <JsonLd schema={org} />
    <JsonLd schema={site} />
    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-FHVX18B0MC"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-FHVX18B0MC');
    </script>
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot name="header"><SiteHeader /></slot>
    <main id="main" class="wrap">
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        <strong>{BRAND}</strong> — independent directory. Not affiliated with Google. Google Docs is a
        trademark of Google LLC.
      </p>
    </footer>
    <PreviewModal />
    <script>
      import "../scripts/directory-island.ts";
    </script>
  </body>
</html>
