---
import { getCollection, render, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import JsonLd from "@components/JsonLd.astro";
import { resolveThumb } from "@lib/assets";
import { creativeWorkSchema, faqSchema } from "@lib/jsonld";
import { templatePath, hubPath } from "@lib/routes";
import { absoluteUrl } from "@lib/site";
import { loadHealthMap, getHealth, ctaState } from "@lib/health";
import type { Template } from "@/content/schema";

type Entry = CollectionEntry<"templates">;

export async function getStaticPaths() {
  const all = await getCollection("templates", ({ data }: Entry) => data.status === "published");
  return all.map((entry: Entry) => ({
    params: { slug: (entry.data as Template).slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: Entry };
const t = entry.data as Template;
const { Content } = await render(entry);
const img = resolveThumb(t.thumbnail.src);

// Related links: prefer the real template name over the raw slug (stronger,
// human-readable anchor text). Fall back to a humanized slug for role/category
// targets that aren't template entries.
const humanize = (s: string) => s.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
const allPublished = await getCollection(
  "templates",
  ({ data }: Entry) => data.status === "published",
);
const nameBySlug = new Map<string, string>(
  allPublished.map((e: Entry) => [(e.data as Template).slug, (e.data as Template).name]),
);
const relatedLinks = t.related.map((r) => ({ slug: r, label: nameBySlug.get(r) ?? humanize(r) }));

const health = getHealth(loadHealthMap(), t.slug);
const cta = ctaState(health, Boolean(t.wordUrl));

const creative = creativeWorkSchema({
  name: t.name,
  url: absoluteUrl(templatePath(t.slug)),
  description: t.seo.metaDescription,
  image: img ? absoluteUrl(img.src) : undefined,
  dateModified: t.updated.toISOString(),
});
---

<BaseLayout
  title={t.seo.title}
  description={t.seo.metaDescription}
  ogImage={t.seo.ogImage}
  robots={t.seo.noindex ? "noindex,follow" : undefined}
>
  <Breadcrumbs
    crumbs={[
      { name: "Templates", href: hubPath() },
      { name: t.name, href: templatePath(t.slug) },
    ]}
  />

  <article class="detail">
    <h1>{t.name} Resume Template{t.kind === "google-doc" ? " for Google Docs" : ""}</h1>

    <div class="detail-grid">
      <div class="detail-preview">
        {
          img && (
            <Image
              src={img}
              alt={t.thumbnail.alt}
              widths={[480, 720, 960]}
              sizes="(max-width: 800px) 90vw, 480px"
            />
          )
        }
      </div>

      <div class="detail-meta">
        <p class="ats-profile">ATS profile: <strong>{t.atsProfile}</strong></p>
        <ul class="ats-checklist">
          {
            t.atsChecklist.map((c) => (
              <li data-pass={String(c.pass)}>
                {c.pass ? "✓" : "✕"} {c.label}
              </li>
            ))
          }
        </ul>

        {
          t.kind === "builder" ? (
            <a class="btn primary block" href={`/resume-builder/?t=${t.builderTemplate}`}>
              Open in the resume builder
            </a>
          ) : cta === "copy" ? (
            <a
              class="btn primary block"
              href={`/go/${t.slug}/`}
              target="_blank"
              rel="noopener"
              data-copy={t.slug}
            >
              Copy in Google Docs
            </a>
          ) : cta === "word" && t.wordUrl ? (
            <a class="btn block" href={t.wordUrl}>
              Download Word version
            </a>
          ) : (
            <button class="btn block" disabled>
              This template is being updated
            </button>
          )
        }

        {
          t.caveats.length > 0 && (
            <ul class="caveats">
              {t.caveats.map((c) => (
                <li>{c}</li>
              ))}
            </ul>
          )
        }
      </div>
    </div>

    <div class="detail-body">
      <Content />
    </div>

    {
      t.faq.length > 0 && (
        <section class="faq detail-faq" aria-labelledby="tpl-faq-h">
          <h2 id="tpl-faq-h">Frequently asked questions</h2>
          <div class="faq-list">
            {t.faq.map((f, i) => (
              <details class="faq-item" name="tpl-faq" open={i === 0}>
                <summary>
                  <span>{f.q}</span>
                  <svg
                    class="faq-chevron"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M6 9l6 6 6-6" />
                  </svg>
                </summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </section>
      )
    }

    {
      relatedLinks.length > 0 && (
        <nav class="related" aria-label="Related templates">
          <h2>Related templates</h2>
          <ul>
            {relatedLinks.map((r) => (
              <li>
                <a href={templatePath(r.slug)}>{r.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }
  </article>

  <JsonLd schema={creative} />
  {t.faq.length > 0 && <JsonLd schema={faqSchema(t.faq)} />}
</BaseLayout>
