---
import Builder from "../../builder/Builder.svelte";
import { SITE_URL, BRAND, DEFAULT_OG_IMAGE, absoluteUrl } from "../../lib/site";
import { softwareAppSchema, serializeJsonLd } from "../../lib/jsonld";
import "../../styles/tokens.css"; // site fonts + palette tokens (self-hosted fonts)

// The builder is an app route (ships JS), separate from the zero-JS SEO pages.
// It complements the directory: SEO pages rank and link here to convert.
const canonical = `${SITE_URL}/resume-builder/`;
const title = "Free Resume Builder — Fill In, Pick a Template, Download PDF";
const description =
  "Build an ATS-friendly resume free. Fill in your details, choose a template, and download a clean PDF with selectable text. No signup, nothing saved to a server.";
const ogImage = absoluteUrl(DEFAULT_OG_IMAGE);

// The builder is a free web app — emit WebApplication JSON-LD so search/AI
// engines surface it as a free resume tool (price is a real, verifiable fact).
const appSchema = softwareAppSchema({
  name: `${BRAND} Resume Builder`,
  url: canonical,
  description,
  applicationCategory: "BusinessApplication",
  image: ogImage,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#4f46e5" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={BRAND} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" is:inline set:html={serializeJsonLd(appSchema)} />
  </head>
  <body>
    <header class="app-header" data-chrome>
      <a class="back" href="/google-docs-resume-template/">← Templates</a>
      <h1>Resume Builder</h1>
      <span class="muted">Free · No signup · ATS-friendly PDF · saved in your browser</span>
    </header>
    <!-- client:only — the builder is a pure client tool (localStorage, window.print);
         SSR'd the wrong template by default (no ?t= server-side), and client:load
         hydration then REUSED that DOM for structurally-similar templates, leaving
         them rendering ATS Minimal. client:only renders each template fresh, correctly. -->
    <Builder client:only="svelte" />

    <style is:global>
      :root {
        font-family: var(--font-sans);
        color: var(--ink);
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        background: var(--paper);
      }
      .app-header {
        height: 48px;
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 0 16px;
        border-bottom: 1px solid var(--line);
        background: var(--bg);
      }
      .app-header .back {
        color: #6366f1;
        text-decoration: none;
        font-size: 0.88rem;
      }
      .app-header h1 {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        margin: 0;
      }
      .app-header .muted {
        color: var(--ink-soft);
        font-size: 0.78rem;
        margin-left: auto;
      }

      /* Print only the resume sheet — real selectable text, ATS-friendly.
         Hide the chrome and flatten the app/preview containers so the sheet sits
         in normal flow and establishes the printed page height. (A previous
         position:absolute approach left the sheet out of flow, so the short app
         height produced a blank page.) */
      @media print {
        @page {
          size: A4;
          margin: 0;
        }
        .app-header,
        [data-chrome] {
          display: none !important;
        }
        .app,
        .builder,
        .preview,
        .stage {
          display: block !important;
          height: auto !important;
          min-height: 0 !important;
          overflow: visible !important;
          padding: 0 !important;
          margin: 0 !important;
          background: none !important;
          box-shadow: none !important;
        }
        [data-sheet] {
          margin: 0 !important;
          box-shadow: none !important;
        }
      }
      @media (max-width: 820px) {
        .app-header .muted {
          display: none;
        }
      }
    </style>
  </body>
</html>
