---
// Quick-preview dialog (D5). The island moves focus in, traps Tab, marks the
// background inert, restores focus on close, and closes on Escape / backdrop.
---

<div id="previewModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle" hidden>
  <div class="modal-card">
    <button id="modalClose" class="btn" aria-label="Close preview">Close</button>
    <h2 id="modalTitle">Template</h2>
    <div id="modalThumb" class="modal-thumb"></div>
    <a id="modalCopy" class="btn primary block" href="#" target="_blank" rel="noopener" data-copy="">
      Copy in Google Docs
    </a>
  </div>
</div>
