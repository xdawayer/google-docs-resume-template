# Production origin (no trailing slash, no www). Build + canonical + sitemap read this.
SITE_URL=https://resumedocs.example

# Google service account JSON (raw, single line) — Drive read-only for screenshot
# export + link-health checks. Used ONLY by scripts/cron, never in the page build.
# Decision #12: standardized name GOOGLE_SA_KEY.
GOOGLE_SA_KEY=

# Google Search Console service-account JSON (URL Inspection + Search Analytics).
GSC_SA_KEY=

# Plausible (analytics proxy target) — domain registered in Plausible.
PLAUSIBLE_DOMAIN=resumedocs.example
PLAUSIBLE_API_HOST=https://plausible.io

# Alerting for the link-health monitor (optional).
SLACK_WEBHOOK_URL=
RESEND_API_KEY=
